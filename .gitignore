# Local editor and OS noise
*~
*.swp
.DS_Store

# Generated backups and caches
*.backup-*
**/__pycache__/
**/.cache/
**/.git/
home/.config/fcitx5/conf/cached_layouts
home/.config/fcitx5/conf/chttrans.conf

# Runtime state and secrets should not live in this repo
home/.config/Code/
home/.config/warp-terminal/
home/.local/state/
*.log
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Machine-local overrides
/local/
*.local
home/.config/environment.d/proxy.conf
!home/.config/tmux/tmux.conf.local

# Tracked helper scripts/assets under the dotfiles home tree.
!home/.local/
!home/.local/bin/
!home/.local/bin/niri-overview-wallpaper
!home/.local/bin/wallpaper-random
!home/.local/share/
!home/.local/share/wallpapers/
