def normalize_command_key(key: str) -> str:
    aliases = {
        "return": "enter",
        "kp_enter": "enter",
        "space": "space",
        "slash": "/",
        "question": "?",
        "minus": "-",
        "equal": "=",
        "period": ".",
        "comma": ",",
        "semicolon": ";",
        "bracketleft": "[",
        "bracketright": "]",
    }
    lowered = key.casefold()
    return aliases.get(lowered, lowered)


def command_key_label(key: str | None) -> str:
    if not key:
        return ""

    normalized = normalize_command_key(key)
    labels = {
        "enter": "Enter",
        "space": "Space",
        "left": "Left",
        "right": "Right",
        "up": "Up",
        "down": "Down",
    }
    if normalized in labels:
        return labels[normalized]
    if len(normalized) == 1:
        return normalized.upper()
    return normalized


def keyval_to_command_key(Gdk: object, keyval: int) -> str | None:
    name = Gdk.keyval_name(keyval)
    if not name:
        return None

    if len(name) == 1:
        return name.casefold()

    return normalize_command_key(name)


def print_plain() -> None:
    print(TITLE)
    print()
    for group, items in GROUPS:
        print(group)
        for item in items:
            command = command_key_label(item.command_key)
            prefix = f"{command:<5}" if command else " " * 5
            print(f"  {prefix} {item.key:<20} {item.label}")
        print()


def command_exists(argv: tuple[str, ...] | None) -> bool:
    return not argv or command_available(argv[0])


def shell_command_exists(command: str | None) -> bool:
    if not command:
        return True

    try:
        parts = shlex.split(command)
    except ValueError:
        return True

    return not parts or command_available(parts[0])


def unavailable_reason(item: Hotkey, target_id: int | None) -> str | None:
    if item.requires_target and target_id is None:
        return "没有可作用的目标窗口"

    if item.argv and not command_exists(item.argv):
        return f"找不到命令：{item.argv[0]}"

    if item.shell and not shell_command_exists(item.shell):
        return f"找不到命令：{shlex.split(item.shell)[0]}"

    if item.niri_action and not niri_available():
        return "niri 会话不可用"

    return None


def run_detached(argv: tuple[str, ...]) -> None:
    subprocess.Popen(argv, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)


def run_quiet(argv: tuple[str, ...]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(argv, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, check=False)


def focused_window_id() -> int | None:
    if not niri_available():
        return None

    result = run_quiet(("niri", "msg", "-j", "focused-window"))
    if result.returncode != 0 or not result.stdout.strip():
        return None

    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError:
        return None

    if not isinstance(data, dict):
        return None

    if data.get("app_id") == APP_ID:
        return None

    window_id = data.get("id")
    return window_id if isinstance(window_id, int) else None


def shortcut_window_ids() -> list[int]:
    if not niri_available():
        return []

    result = run_quiet(("niri", "msg", "-j", "windows"))
    if result.returncode != 0 or not result.stdout.strip():
        return []

    try:
        windows = json.loads(result.stdout)
    except json.JSONDecodeError:
        return []

    shortcut_windows = [window for window in windows if window.get("app_id") == APP_ID]
    shortcut_windows.sort(
        key=lambda window: (
            (window.get("focus_timestamp") or {}).get("secs") or 0,
            (window.get("focus_timestamp") or {}).get("nanos") or 0,
        )
    )

    ids: list[int] = []
    for window in shortcut_windows:
        window_id = window.get("id")
        if isinstance(window_id, int):
            ids.append(window_id)
    return ids


def focus_window(window_id: int | None) -> bool:
    if window_id is None:
        return False

    return run_quiet(("niri", "msg", "action", "focus-window", "--id", str(window_id))).returncode == 0


def focus_existing_shortcuts() -> bool:
    ids = shortcut_window_ids()
    if not ids:
        return False

    for old_id in ids[:-1]:
        run_quiet(("niri", "msg", "action", "close-window", "--id", str(old_id)))

    current_id = ids[-1]
    focus_window(current_id)
    return True


def wait_for_existing_shortcuts(timeout: float = 0.6) -> bool:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if focus_existing_shortcuts():
            return True
        time.sleep(0.025)
    return focus_existing_shortcuts()


def niri_action(action: tuple[str, ...], target_id: int | None, requires_target: bool) -> bool:
    if not niri_available():
        return False

    if target_id is not None:
        if requires_target and not focus_window(target_id):
            return False
    elif requires_target:
        return False

    return run_quiet(("niri", "msg", "action", *action)).returncode == 0


def prepare_target_focus(item: Hotkey, target_id: int | None) -> bool:
    if not item.focus_target:
        return True

    if target_id is not None and focus_window(target_id):
        return True

    return not item.requires_target


def hotkey_runner(item: Hotkey, target_id: int | None, close: Callable[[], None]) -> Callable[[], None]:
    def run() -> None:
        if unavailable_reason(item, target_id):
            return

        ran = False
        if item.niri_action:
            ran = niri_action(item.niri_action, target_id if item.focus_target else None, item.requires_target)
        elif item.shell:
            if not prepare_target_focus(item, target_id):
                return
            run_detached(("sh", "-lc", item.shell))
            ran = True
        elif item.argv and command_exists(item.argv):
            if not prepare_target_focus(item, target_id):
                return
            run_detached(item.argv)
            ran = True

        if ran:
            close()

    return run


def load_gtk() -> tuple[object, object, object, object, object]:
    import gi

    gi.require_version("Gdk", "4.0")
    gi.require_version("Gtk", "4.0")
    from gi.repository import Gdk, Gio, GLib, Gtk, Pango

    return Gtk, Gdk, Gio, GLib, Pango


def build_ui(app: object, target_id: int | None, persistent: bool = False) -> ShortcutsWindow:
    Gtk, Gdk, _Gio, _GLib, Pango = load_gtk()

    css = """
    window {
      background: #11111b;
      color: #cdd6f4;
    }
    .root {
      padding: 20px;
    }
    .title {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 2px;
    }
    .subtitle {
      color: #a6adc8;
      font-size: 12px;
      margin-bottom: 12px;
    }
    .group-card {
      background: #1e1e2e;
      border: 1px solid #313244;
      border-radius: 10px;
      padding: 12px;
      margin: 6px;
    }
    .group-title {
      color: #89dceb;
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    button.hotkey-row {
      background: transparent;
      border-radius: 8px;
      padding: 7px 8px;
      margin: 2px 0;
      color: #cdd6f4;
    }
    button.hotkey-row:hover {
      background: #313244;
    }
    .keycap {
      background: #181825;
      border: 1px solid #45475a;
      border-radius: 6px;
      color: #f5c2e7;
      font-family: "JetBrains Mono", monospace;
      font-size: 11px;
      font-weight: 700;
      padding: 4px 7px;
      min-width: 150px;
    }
    .command-keycap {
      background: #f38ba8;
      border-radius: 6px;
      color: #11111b;
      font-family: "JetBrains Mono", monospace;
      font-size: 12px;
      font-weight: 800;
      padding: 4px 7px;
      min-width: 26px;
    }
    .action-label {
      color: #cdd6f4;
      font-size: 13px;
      font-weight: 500;
    }
    .disabled-row {
      opacity: 0.45;
    }
    """
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode())
    display = Gdk.Display.get_default()
    if display:
        Gtk.StyleContext.add_provider_for_display(display, provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.ApplicationWindow(application=app)
    window.set_title(TITLE)
    window.set_default_size(1040, 720)
    window.set_resizable(True)

    target_state = {"id": target_id}
    commands_state: dict[str, dict[str, Hotkey]] = {"value": {}}
    row_states: list[tuple[Hotkey, object]] = []
    seen_active = {"value": False}

    def close_window() -> None:
        seen_active["value"] = False
        if persistent:
            window.set_visible(False)
        else:
            window.close()

    def on_close_request(_window: object) -> bool:
        if persistent:
            close_window()
            return True
        return False

    window.connect("close-request", on_close_request)

    def update_row_state(row: object, reason: str | None) -> None:
        if reason:
            row.add_css_class("disabled-row")
            row.set_sensitive(False)
            row.set_tooltip_text(reason)
        else:
            row.remove_css_class("disabled-row")
            row.set_sensitive(True)
            row.set_tooltip_text(None)

    def refresh_target(new_target_id: int | None) -> None:
        target_state["id"] = new_target_id
        commands: dict[str, Hotkey] = {}
        for item, row in row_states:
            reason = unavailable_reason(item, new_target_id)
            update_row_state(row, reason)
            if item.command_key and not reason:
                commands.setdefault(normalize_command_key(item.command_key), item)
        commands_state["value"] = commands

    def present_window(new_target_id: int | None) -> None:
        seen_active["value"] = False
        refresh_target(new_target_id)
        window.present()

    key_controller = Gtk.EventControllerKey()
    key_controller.set_propagation_phase(Gtk.PropagationPhase.CAPTURE)

    def on_key_pressed(_controller: object, keyval: int, _keycode: int, _state: object) -> bool:
        if keyval == Gdk.KEY_Escape:
            close_window()
            return True
        command = keyval_to_command_key(Gdk, keyval)
        item = commands_state["value"].get(command or "")
        if item:
            hotkey_runner(item, target_state["id"], close_window)()
            return True
        return False

    key_controller.connect("key-pressed", on_key_pressed)
    window.add_controller(key_controller)

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    root.add_css_class("root")
    window.set_child(root)

    header = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    root.append(header)

    title = Gtk.Label(label="Important Hotkeys")
    title.add_css_class("title")
    title.set_xalign(0)
    header.append(title)

    subtitle = Gtk.Label(label="按键速查和常用动作")
    subtitle.add_css_class("subtitle")
    subtitle.set_xalign(0)
    header.append(subtitle)

    scroller = Gtk.ScrolledWindow()
    scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    scroller.set_vexpand(True)
    root.append(scroller)

    grid = Gtk.Grid()
    grid.set_column_homogeneous(True)
    grid.set_row_homogeneous(False)
    grid.set_column_spacing(8)
    grid.set_row_spacing(8)
    scroller.set_child(grid)

    def on_active_changed(_window: object, _param: object) -> None:
        if window.is_active():
            seen_active["value"] = True
        elif seen_active["value"]:
            close_window()

    window.connect("notify::is-active", on_active_changed)

    for index, (group, items) in enumerate(GROUPS):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        card.add_css_class("group-card")

        group_label = Gtk.Label(label=group)
        group_label.add_css_class("group-title")
        group_label.set_xalign(0)
        card.append(group_label)

        for item in items:
            row = Gtk.Button()
            row.add_css_class("hotkey-row")
            row_states.append((item, row))
            update_row_state(row, unavailable_reason(item, target_id))

            content = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            content.set_hexpand(True)
            row.set_child(content)

            command = Gtk.Label(label=command_key_label(item.command_key))
            command.add_css_class("command-keycap")
            command.set_xalign(0.5)
            command.set_tooltip_text("窗口打开后可直接按这个键执行")
            if not item.command_key:
                command.set_opacity(0)
            content.append(command)

            key = Gtk.Label(label=item.key)
            key.add_css_class("keycap")
            key.set_xalign(0.5)
            key.set_wrap(True)
            key.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
            key.set_width_chars(16)
            key.set_max_width_chars(22)
            content.append(key)

            label = Gtk.Label(label=item.label)
            label.add_css_class("action-label")
            label.set_xalign(0)
            label.set_hexpand(True)
            label.set_wrap(True)
            label.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
            content.append(label)

            row.connect("clicked", lambda _button, hotkey=item: hotkey_runner(hotkey, target_state["id"], close_window)())
            card.append(row)

        grid.attach(card, index % 3, index // 3, 1, 1)

    refresh_target(target_id)
    return ShortcutsWindow(window=window, present=present_window, close=close_window)


def run_daemon() -> int:
    if not (os.environ.get("WAYLAND_DISPLAY") or os.environ.get("DISPLAY")):
        return 1

    daemon_lock = acquire_lock(DAEMON_LOCK)
    if daemon_lock is None:
        return 0

    Gtk, _Gdk, Gio, GLib, _Pango = load_gtk()
    app = Gtk.Application(application_id=APP_ID, flags=Gio.ApplicationFlags.FLAGS_NONE)
    controller: dict[str, ShortcutsWindow | None] = {"value": None}
    stop_event = threading.Event()
    server_socket: dict[str, socket.socket | None] = {"value": None}

    def show_window() -> bool:
        target_id = focused_window_id()
        if controller["value"] is None:
            controller["value"] = build_ui(app, target_id, persistent=True)
        controller["value"].present(target_id)
        return False

    def preload_window() -> bool:
        if controller["value"] is None:
            controller["value"] = build_ui(app, None, persistent=True)
        return False

    def shutdown() -> bool:
        app.quit()
        return False

    def cleanup() -> None:
        stop_event.set()
        server = server_socket["value"]
        if server is not None:
            try:
                server.close()
            except OSError:
                pass
        remove_stale_control_socket()

    def handle_client(conn: socket.socket) -> None:
        try:
            data = conn.recv(1024).decode("utf-8", errors="replace").strip()
        except OSError:
            return

        if data == "show":
            GLib.idle_add(show_window)
        elif data == "quit":
            GLib.idle_add(shutdown)

    def serve() -> None:
        remove_stale_control_socket()
        server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        server_socket["value"] = server
        try:
            server.bind(control_socket_path())
            os.chmod(control_socket_path(), 0o600)
            server.listen(16)
            server.settimeout(0.5)
            while not stop_event.is_set():
                try:
                    conn, _addr = server.accept()
                except socket.timeout:
                    continue
                except OSError:
                    break

                with conn:
                    handle_client(conn)
        finally:
            try:
                server.close()
            except OSError:
                pass
            remove_stale_control_socket()

    def on_startup(_app: object) -> None:
        threading.Thread(target=serve, daemon=True).start()
        GLib.idle_add(preload_window)

    atexit.register(cleanup)
    app.hold()
    app.connect("startup", on_startup)
    app.connect("activate", lambda _app: None)
    app.connect("shutdown", lambda _app: cleanup())
    return app.run((sys.argv[0],))


def main() -> int:
    if "--quit-daemon" in sys.argv:
        return 0 if send_daemon_command("quit") else 1

    if "--daemon" in sys.argv:
        return run_daemon()

    if "--print" in sys.argv:
        print_plain()
        return 0

    if not (os.environ.get("WAYLAND_DISPLAY") or os.environ.get("DISPLAY")):
        print_plain()
        return 0

    if not _FAST_DAEMON_ATTEMPTED and show_via_daemon():
        return 0

    if focus_existing_shortcuts():
        return 0

    startup_lock = acquire_startup_lock()
    if startup_lock is None:
        wait_for_existing_shortcuts()
        return 0

    if focus_existing_shortcuts():
        return 0

    Gtk, _Gdk, Gio, _GLib, _Pango = load_gtk()
    target_id = focused_window_id()

    app = Gtk.Application(application_id=APP_ID, flags=Gio.ApplicationFlags.FLAGS_NONE)
    app.connect("activate", lambda gtk_app: build_ui(gtk_app, target_id).present(target_id))
    return app.run(sys.argv)


if __name__ == "__main__":
    raise SystemExit(main())
