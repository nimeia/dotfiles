        ),
    ),
)


def print_plain() -> None:
    print(TITLE)
    print()
    for group, items in GROUPS:
        print(group)
        for item in items:
            print(f"  {item.key:<20} {item.label}")
        print()


def command_exists(argv: tuple[str, ...] | None) -> bool:
    return not argv or shutil.which(argv[0]) is not None


def shell_command_exists(command: str | None) -> bool:
    if not command:
        return True

    try:
        parts = shlex.split(command)
    except ValueError:
        return True

    return not parts or shutil.which(parts[0]) is not None


def unavailable_reason(item: Hotkey, target_id: int | None) -> str | None:
    if item.requires_target and target_id is None:
        return "没有可作用的目标窗口"

    if item.argv and not command_exists(item.argv):
        return f"找不到命令：{item.argv[0]}"

    if item.shell and not shell_command_exists(item.shell):
        return f"找不到命令：{shlex.split(item.shell)[0]}"

    if item.niri_action and (not os.environ.get("NIRI_SOCKET") or not shutil.which("niri")):
        return "niri 会话不可用"

    return None


def run_detached(argv: tuple[str, ...]) -> None:
    subprocess.Popen(argv, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)


def run_quiet(argv: tuple[str, ...]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(argv, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, check=False)


def focused_window_id() -> int | None:
    if not os.environ.get("NIRI_SOCKET") or not shutil.which("niri"):
        return None

    result = run_quiet(("niri", "msg", "-j", "focused-window"))
    if result.returncode != 0 or not result.stdout.strip():
        return None

    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError:
        return None

    if not isinstance(data, dict):
        return None

    if data.get("app_id") == APP_ID:
        return None

    window_id = data.get("id")
    return window_id if isinstance(window_id, int) else None


def shortcut_window_ids() -> list[int]:
    if not os.environ.get("NIRI_SOCKET") or not shutil.which("niri"):
        return []

    result = run_quiet(("niri", "msg", "-j", "windows"))
    if result.returncode != 0 or not result.stdout.strip():
        return []

    try:
        windows = json.loads(result.stdout)
    except json.JSONDecodeError:
        return []

    shortcut_windows = [window for window in windows if window.get("app_id") == APP_ID]
    shortcut_windows.sort(
        key=lambda window: (
            (window.get("focus_timestamp") or {}).get("secs") or 0,
            (window.get("focus_timestamp") or {}).get("nanos") or 0,
        )
    )

    ids: list[int] = []
    for window in shortcut_windows:
        window_id = window.get("id")
        if isinstance(window_id, int):
            ids.append(window_id)
    return ids


def focus_window(window_id: int | None) -> bool:
    if window_id is None:
        return False

    return run_quiet(("niri", "msg", "action", "focus-window", "--id", str(window_id))).returncode == 0


def focus_existing_shortcuts() -> bool:
    ids = shortcut_window_ids()
    if not ids:
        return False

    for old_id in ids[:-1]:
        run_quiet(("niri", "msg", "action", "close-window", "--id", str(old_id)))

    current_id = ids[-1]
    focus_window(current_id)
    run_quiet(("niri", "msg", "action", "set-window-width", "--id", str(current_id), "1040"))
    run_quiet(("niri", "msg", "action", "set-window-height", "--id", str(current_id), "720"))
    run_quiet(("niri", "msg", "action", "center-window", "--id", str(current_id)))
    return True


def niri_action(action: tuple[str, ...], target_id: int | None, requires_target: bool) -> bool:
    if not shutil.which("niri"):
        return False

    if target_id is not None:
        if requires_target and not focus_window(target_id):
            return False
    elif requires_target:
        return False

    return run_quiet(("niri", "msg", "action", *action)).returncode == 0


def prepare_target_focus(item: Hotkey, target_id: int | None) -> bool:
    if not item.focus_target:
        return True

    if target_id is not None and focus_window(target_id):
        return True

    return not item.requires_target


def hotkey_runner(item: Hotkey, target_id: int | None, close: Callable[[], None]) -> Callable[[], None]:
    def run() -> None:
        if unavailable_reason(item, target_id):
            return

        ran = False
        if item.niri_action:
            ran = niri_action(item.niri_action, target_id if item.focus_target else None, item.requires_target)
        elif item.shell:
            if not prepare_target_focus(item, target_id):
                return
            run_detached(("sh", "-lc", item.shell))
            ran = True
        elif item.argv and command_exists(item.argv):
            if not prepare_target_focus(item, target_id):
                return
            run_detached(item.argv)
            ran = True

        if ran:
            close()

    return run


def load_gtk() -> tuple[object, object, object, object]:
    import gi

    gi.require_version("Gdk", "4.0")
    gi.require_version("Gtk", "4.0")
    from gi.repository import Gdk, Gio, Gtk, Pango

    return Gtk, Gdk, Gio, Pango


def build_ui(app: object, target_id: int | None) -> None:
    Gtk, Gdk, _Gio, Pango = load_gtk()

    css = """
    window {
      background: #11111b;
      color: #cdd6f4;
    }
    .root {
      padding: 20px;
    }
    .title {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 2px;
    }
    .subtitle {
      color: #a6adc8;
      font-size: 12px;
      margin-bottom: 12px;
    }
    .group-card {
      background: #1e1e2e;
      border: 1px solid #313244;
      border-radius: 10px;
      padding: 12px;
      margin: 6px;
    }
    .group-title {
      color: #89dceb;
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    button.hotkey-row {
      background: transparent;
      border-radius: 8px;
      padding: 7px 8px;
      margin: 2px 0;
      color: #cdd6f4;
    }
    button.hotkey-row:hover {
      background: #313244;
    }
    .keycap {
      background: #181825;
      border: 1px solid #45475a;
      border-radius: 6px;
      color: #f5c2e7;
      font-family: "JetBrains Mono", monospace;
      font-size: 11px;
      font-weight: 700;
      padding: 4px 7px;
      min-width: 150px;
    }
    .action-label {
      color: #cdd6f4;
      font-size: 13px;
      font-weight: 500;
    }
    .disabled-row {
      opacity: 0.45;
    }
    """
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode())
    display = Gdk.Display.get_default()
    if display:
        Gtk.StyleContext.add_provider_for_display(display, provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.ApplicationWindow(application=app)
    window.set_title(TITLE)
    window.set_default_size(1040, 720)
    window.set_resizable(True)

    key_controller = Gtk.EventControllerKey()
    key_controller.set_propagation_phase(Gtk.PropagationPhase.CAPTURE)

    def on_key_pressed(_controller: object, keyval: int, _keycode: int, _state: object) -> bool:
        if keyval == Gdk.KEY_Escape:
            window.close()
            return True
        return False

    key_controller.connect("key-pressed", on_key_pressed)
    window.add_controller(key_controller)

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    root.add_css_class("root")
    window.set_child(root)

    header = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    root.append(header)

    title = Gtk.Label(label="Important Hotkeys")
    title.add_css_class("title")
    title.set_xalign(0)
    header.append(title)

    subtitle = Gtk.Label(label="按键速查和常用动作")
    subtitle.add_css_class("subtitle")
    subtitle.set_xalign(0)
    header.append(subtitle)

    scroller = Gtk.ScrolledWindow()
    scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    scroller.set_vexpand(True)
    root.append(scroller)

    grid = Gtk.Grid()
    grid.set_column_homogeneous(True)
    grid.set_row_homogeneous(False)
    grid.set_column_spacing(8)
    grid.set_row_spacing(8)
    scroller.set_child(grid)

    def close_window() -> None:
        window.close()

    seen_active = {"value": False}

    def on_active_changed(_window: object, _param: object) -> None:
        if window.is_active():
            seen_active["value"] = True
        elif seen_active["value"]:
            close_window()

    window.connect("notify::is-active", on_active_changed)

    for index, (group, items) in enumerate(GROUPS):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        card.add_css_class("group-card")

        group_label = Gtk.Label(label=group)
        group_label.add_css_class("group-title")
        group_label.set_xalign(0)
        card.append(group_label)

        for item in items:
            row = Gtk.Button()
            row.add_css_class("hotkey-row")
            reason = unavailable_reason(item, target_id)
            if reason:
                row.add_css_class("disabled-row")
                row.set_sensitive(False)
                row.set_tooltip_text(reason)

            content = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            content.set_hexpand(True)
            row.set_child(content)

            key = Gtk.Label(label=item.key)
            key.add_css_class("keycap")
            key.set_xalign(0.5)
            key.set_wrap(True)
            key.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
            key.set_width_chars(16)
            key.set_max_width_chars(22)
            content.append(key)

            label = Gtk.Label(label=item.label)
            label.add_css_class("action-label")
            label.set_xalign(0)
            label.set_hexpand(True)
            label.set_wrap(True)
            label.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
            content.append(label)

            runner = hotkey_runner(item, target_id, close_window)
            row.connect("clicked", lambda _button, callback=runner: callback())
            card.append(row)

        grid.attach(card, index % 3, index // 3, 1, 1)

    window.present()

    if os.environ.get("NIRI_SOCKET") and shutil.which("niri"):
        run_quiet(("niri", "msg", "action", "set-window-width", "1040"))
        run_quiet(("niri", "msg", "action", "set-window-height", "720"))
        run_quiet(("niri", "msg", "action", "center-window"))


def main() -> int:
    if "--print" in sys.argv:
        print_plain()
        return 0

    if not (os.environ.get("WAYLAND_DISPLAY") or os.environ.get("DISPLAY")):
        print_plain()
        return 0

    if focus_existing_shortcuts():
        return 0

    Gtk, _Gdk, Gio, _Pango = load_gtk()
    target_id = focused_window_id()

    app = Gtk.Application(application_id=APP_ID, flags=Gio.ApplicationFlags.FLAGS_NONE)
    app.connect("activate", lambda gtk_app: build_ui(gtk_app, target_id))
    return app.run(sys.argv)


if __name__ == "__main__":
    raise SystemExit(main())
