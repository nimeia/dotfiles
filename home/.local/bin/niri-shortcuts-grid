from __future__ import annotations

import json
import os
import shlex
import shutil
import subprocess
import sys
from dataclasses import dataclass
from typing import Callable


APP_ID = "dev.sakura.NiriShortcuts"
TITLE = "Important Hotkeys"


@dataclass(frozen=True)
class Hotkey:
    key: str
    label: str
    argv: tuple[str, ...] | None = None
    shell: str | None = None
    niri_action: tuple[str, ...] | None = None
    focus_target: bool = False
    requires_target: bool = False


