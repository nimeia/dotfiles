#!/usr/bin/env python3
from __future__ import annotations

import os
import subprocess
import sys
import socket
import time


APP_ID = "dev.sakura.NiriShortcuts"
TITLE = "Important Hotkeys"
HOME = os.path.expanduser("~")
LOCAL_BIN = os.path.join(HOME, ".local", "bin")
CONTROL_SOCKET = "niri-shortcuts-grid.sock"
STARTUP_LOCK = "niri-shortcuts-grid.lock"
DAEMON_LOCK = "niri-shortcuts-grid.daemon.lock"


def runtime_dir() -> str:
    return os.environ.get("XDG_RUNTIME_DIR") or f"/run/user/{os.getuid()}"


def runtime_path(name: str) -> str:
    return os.path.join(runtime_dir(), name)


def acquire_lock(name: str) -> int | None:
    lock_path = runtime_path(name)
    fd: int | None = None
    try:
        fd = os.open(lock_path, os.O_CREAT | os.O_RDWR, 0o600)
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        if fd is not None:
            os.close(fd)
        return None
    return fd


def acquire_startup_lock() -> int | None:
    return acquire_lock(STARTUP_LOCK)


def control_socket_path() -> str:
    return runtime_path(CONTROL_SOCKET)


def remove_stale_control_socket() -> None:
    path = control_socket_path()
    try:
        os.unlink(path)
    except FileNotFoundError:
        pass
    except OSError:
        pass


def send_daemon_command(command: str, timeout: float = 0.15) -> bool:
    client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    client.settimeout(timeout)
    try:
        client.connect(control_socket_path())
        client.sendall(command.encode("utf-8") + b"\n")
        return True
    except OSError:
        remove_stale_control_socket()
        return False
    finally:
        client.close()


def start_daemon() -> None:
    script = os.path.realpath(__file__)
    subprocess.Popen(
        (sys.executable or "python3", script, "--daemon"),
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def show_via_daemon() -> bool:
    if send_daemon_command("show"):
        return True

    start_daemon()
    deadline = time.monotonic() + 1.5
    while time.monotonic() < deadline:
        if send_daemon_command("show"):
            return True
        time.sleep(0.025)
    return False


_FAST_DAEMON_ATTEMPTED = False


def fast_client_entry() -> None:
    global _FAST_DAEMON_ATTEMPTED

    args = set(sys.argv[1:])
    if "--quit-daemon" in args:
        raise SystemExit(0 if send_daemon_command("quit") else 1)

    if args or not (os.environ.get("WAYLAND_DISPLAY") or os.environ.get("DISPLAY")):
        return

    _FAST_DAEMON_ATTEMPTED = True
    if show_via_daemon():
        raise SystemExit(0)


fast_client_entry()

import atexit
import fcntl
import json
import shlex
import shutil
import threading
from glob import glob
from dataclasses import dataclass
from typing import Callable


_COMMAND_EXISTS_CACHE: dict[str, bool] = {}
_NIRI_AVAILABLE: bool | None = None


def ensure_niri_socket() -> bool:
    if os.environ.get("NIRI_SOCKET"):
        return True

    sockets = glob(os.path.join(runtime_dir(), "niri.*.sock"))
    if not sockets:
        return False

    sockets.sort(key=lambda path: os.stat(path).st_mtime, reverse=True)
    os.environ["NIRI_SOCKET"] = sockets[0]
    return True


def command_available(command: str) -> bool:
    if command not in _COMMAND_EXISTS_CACHE:
        _COMMAND_EXISTS_CACHE[command] = shutil.which(command) is not None
    return _COMMAND_EXISTS_CACHE[command]


def niri_available() -> bool:
    global _NIRI_AVAILABLE
    if _NIRI_AVAILABLE is None:
        _NIRI_AVAILABLE = ensure_niri_socket() and command_available("niri")
    return _NIRI_AVAILABLE


@dataclass(frozen=True)
class Hotkey:
    key: str
    label: str
    command_key: str | None = None
    argv: tuple[str, ...] | None = None
    shell: str | None = None
    niri_action: tuple[str, ...] | None = None
    focus_target: bool = False
    requires_target: bool = False


@dataclass(frozen=True)
class ShortcutsWindow:
    window: object
    present: Callable[[int | None], None]
    close: Callable[[], None]


