#!/usr/bin/env bash
set -euo pipefail

DEFAULT_COLUMN_WIDTH="94%"

usage() {
    cat >&2 <<'EOF'
Usage: niri-layout <half|third|wide|stack|unstack|reset>

  half     Set current and adjacent columns to 50%.
  third    Set current and nearby columns to about 1/3 screen width.
  wide     Set current column to about 2/3 and adjacent column to 1/3.
  stack    Consume the right column into the current column for vertical split.
  unstack  Expel the bottom window from the current column.
  reset    Restore the current column to the default layout.
EOF
}

require_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        printf 'Required command not found: %s\n' "$1" >&2
        exit 1
    fi
}

require_session() {
    require_command niri
    require_command jq

    if [ -z "${NIRI_SOCKET:-}" ]; then
        printf 'NIRI_SOCKET is not set; run this inside a niri session.\n' >&2
        exit 1
    fi
}

action() {
    niri msg action "$@"
}

try_action() {
    niri msg action "$@" >/dev/null 2>&1
}

focused_window_id() {
    niri msg -j focused-window 2>/dev/null | jq -r '.id // empty'
}

require_focused_window() {
    local window_id

    window_id="$(focused_window_id)"
    if [ -z "$window_id" ]; then
        printf 'No focused niri window found.\n' >&2
        exit 1
    fi

    printf '%s\n' "$window_id"
}

focus_window_id() {
    local window_id=$1

    [ -n "$window_id" ] || return 1
    try_action focus-window --id "$window_id"
}

prepare_current_window() {
    try_action move-window-to-tiling || true
    try_action reset-window-height || true
}

set_current_column_width() {
    action set-column-width "$1" >/dev/null
}

set_current_window_height() {
    action set-window-height "$1" >/dev/null
}

focused_column_window_count() {
    local window_id=$1

    niri msg -j windows 2>/dev/null | jq -r --argjson id "$window_id" '
        . as $wins
        | ($wins | map(select(.id == $id)) | .[0]) as $focused
        | if $focused == null or $focused.layout.pos_in_scrolling_layout == null then
            0
          else
            [
              $wins[]
              | select(.workspace_id == $focused.workspace_id)
              | select(.layout.pos_in_scrolling_layout[0]? == $focused.layout.pos_in_scrolling_layout[0])
            ]
            | length
          end
    ' 2>/dev/null || printf '0\n'
}

expel_windows_until_current_is_single() {
    local original_id=$1
    local count next_count
    local i

    for ((i = 0; i < 12; i++)); do
        focus_window_id "$original_id" || break
        count="$(focused_column_window_count "$original_id")"
        [ "$count" -gt 1 ] 2>/dev/null || break

        try_action expel-window-from-column || break

        focus_window_id "$original_id" || break
        next_count="$(focused_column_window_count "$original_id")"
        if [ "$next_count" -ge "$count" ] 2>/dev/null; then
            break
        fi
    done
}

set_neighbor_column_width() {
    local original_id=$1
    local direction=$2
    local width=$3
    local before_id
    local after_id

    focus_window_id "$original_id" || return 1
    before_id="$(focused_window_id || true)"

    if ! try_action "focus-column-$direction"; then
        focus_window_id "$original_id" || true
        return 1
    fi

    after_id="$(focused_window_id || true)"
    if [ -z "$after_id" ] || [ "$after_id" = "$before_id" ]; then
        focus_window_id "$original_id" || true
        return 1
    fi

    try_action set-column-width "$width" || true
    focus_window_id "$original_id" || true
}

layout_half() {
    local original_id

    original_id="$(require_focused_window)"
    prepare_current_window
    set_current_column_width "50%"
    set_neighbor_column_width "$original_id" right "50%" || set_neighbor_column_width "$original_id" left "50%" || true
    try_action center-visible-columns || true
    focus_window_id "$original_id" || true
}

layout_third() {
    local original_id

    original_id="$(require_focused_window)"
    prepare_current_window
    set_current_column_width "33%"
    set_neighbor_column_width "$original_id" left "33%" || true
    set_neighbor_column_width "$original_id" right "33%" || true
    try_action center-visible-columns || true
    focus_window_id "$original_id" || true
}

layout_wide() {
    local original_id

    original_id="$(require_focused_window)"
    prepare_current_window
    set_current_column_width "67%"
    set_neighbor_column_width "$original_id" right "33%" || set_neighbor_column_width "$original_id" left "33%" || true
    try_action center-visible-columns || true
    focus_window_id "$original_id" || true
}

layout_stack() {
    local original_id

    original_id="$(require_focused_window)"
    prepare_current_window
    set_current_column_width "50%"
    try_action consume-window-into-column || true
    focus_window_id "$original_id" || true
    set_current_window_height "50%" || true
    try_action center-column || true
}

layout_unstack() {
    local original_id

    original_id="$(require_focused_window)"
    try_action expel-window-from-column || true
    focus_window_id "$original_id" || true
    try_action reset-window-height || true
    try_action center-visible-columns || true
}

layout_reset() {
    local original_id

    original_id="$(require_focused_window)"
    prepare_current_window
    expel_windows_until_current_is_single "$original_id"
    focus_window_id "$original_id" || true
    try_action reset-window-height || true
    set_current_column_width "$DEFAULT_COLUMN_WIDTH"
    try_action center-column || true
    focus_window_id "$original_id" || true
}

main() {
    local command=${1:-}

    case "$command" in
        -h|--help|help)
            usage
            return
            ;;
        "")
            usage
            exit 2
            ;;
    esac

    require_session

    case "$command" in
        half)
            layout_half
            ;;
        third)
            layout_third
            ;;
        wide)
            layout_wide
            ;;
        stack)
            layout_stack
            ;;
        unstack)
            layout_unstack
            ;;
        reset)
            layout_reset
            ;;
        *)
            usage
            exit 2
            ;;
    esac
}

main "$@"
