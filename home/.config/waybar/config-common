{
  "height": 48,
  "clock#time": {
    "format": "{:%H:%M}",
    "tooltip-format": "{:L%a, %d %b %H:%M}",
    "interval": 1,
    "tooltip": false
  },
  "clock#date": {
    "format": "{:L%a %b %d}",
    "interval": 1
  },
  "group/datetime": {
    "orientation": "horizontal",
    "drawer": {
      "transition-left-to-right": false
    },
    "modules": [
      "clock#time",
      "clock#date"
    ]
  },
  "group/battery": {
    "orientation": "horizontal",
    "modules": [
      "battery#prefix",
      "battery#suffix"
    ]
  },
  "battery#prefix": {
    "bat": "BAT0",
    "adapter": "ADP0",
    "format": " {icon}",
    "format-charging": " 󰂄",
    "format-plugged": " 󰂄",
    "format-full": " 󰁹",
    "format-icons": [
      "󰁺",
      "󰁼",
      "󰁾",
      "󰂁",
      "󰁹"
    ],
    "states": {
      "warning": 30,
      "critical": 15
    },
    "interval": 10,
    "tooltip": false
  },
  "battery#suffix": {
    "bat": "BAT0",
    "adapter": "ADP0",
    "format": "{capacity}%",
    "format-charging": "{capacity}%",
    "format-plugged": "{capacity}%",
    "format-full": "{capacity}%",
    "format-time": "{H}h {M}m",
    "tooltip": true,
    "tooltip-format": "电池: {capacity}%\n功耗: {power}W\n预计时间: {time}",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "interval": 10
  },
  "privacy": {
    "icon-size": 12,
    "icon-spacing": 8
  },
  "group/network": {
    "orientation": "horizontal",
    "drawer": {},
    "modules": [
      "network#status",
      "network#uplprefix",
      "network#up",
      "network#dnlprefix",
      "network#down"
    ]
  },
  "network#statusprefix": {
    "format-wifi": " ",
    "format-ethernet": " 󰈀",
    "format-disconnected": " 󰌙",
    "tooltip-format": "{ifname} via {gwaddr} ",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ",
    "tooltip-format-ethernet": "{ifname} ",
    "tooltip-format-disconnected": "Disconnected"
  },
  "network#status": {
    "format-wifi": "{signalStrength}%",
    "format-ethernet": "LAN",
    "format-disconnected": "",
    "tooltip-format": "{ifname} via {gwaddr}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50
  },
  "network#uplprefix": {
    "format-wifi": " 󰬬",
    "format-ethernet": " 󰬬",
    "format-disconnected": "",
    "tooltip": false
  },
  "network#dnlprefix": {
    "format-wifi": " 󰬦",
    "format-ethernet": " 󰬦",
    "format-disconnected": "",
    "tooltip": false
  },
  "network#up": {
    "format-wifi": "{bandwidthUpBytes}",
    "format-ethernet": "{bandwidthUpBytes}",
    "interval": 1
  },
  "network#down": {
    "format-wifi": "{bandwidthDownBytes}",
    "format-ethernet": "{bandwidthDownBytes}",
    "interval": 1
  },
  "clock#centered": {
    "format": " {:%a, %d %b %H:%M} ",
    "interval": 1
  },
  "custom/app": {
    "format": " Applications ",
    "tooltip": false,
    "on-click": "nwg-drawer"
  },
  "mpris#prefix": {
    "format": "{status_icon}",
    "status-icons": {
      "playing": "",
      "paused": "",
      "stopped": ""
    }
  },
  "mpris#suffix": {
    "format": "",
    "format-playing": "{dynamic} ",
    "format-paused": "{dynamic} ",
    "format-stopped": "{dynamic} ",
    "dynamic-len": 50,
    "dynamic-order": [
      "artist",
      "title"
    ]
  },
  "custom/playerctl#prefix": {
    "exec": "~/.config/waybar/scripts/playerctl-status -s 2> /dev/null ",
    "format": "{}",
    "interval": 1
  },
  "custom/playerctl#suffix": {
    "exec": "~/.config/waybar/scripts/playerctl-status 2> /dev/null",
    "format": "{}  ",
    "interval": 1
  },
  "custom/timeprefix": {
    "format": " ",
    "tooltip": false
  },
  "custom/dateprefix": {
    "format": "  ",
    "tooltip": false
  },
  "custom/memoryprefix": {
    "format": " 󰍛",
    "tooltip": false
  },
  "memory": {
    "tooltip-format": "{used:0.2f}/{total:0.2f} GB Used"
  },
  "network#cpuprefixon": {
    "format-wifi": " ",
    "format-ethernet": " ",
    "format-disconnected": "",
    "tooltip": false
  },
  "custom/cpuprefix": {
    "format": " ",
    "tooltip": false
  },
  "custom/barpadding": {
    "format": " ",
    "tooltip": false
  },
  "cpu": {
    "format": "{usage}%"
  },
  "pulseaudio#prefix": {
    "format": "{icon} {volume}%",
    "format-muted": "󰝟 静音",
    "format-icons": {
      "default": [
        "󰕿",
        "󰖀",
        "󰕾"
      ]
    },
    "tooltip": true,
    "tooltip-format": "{desc}\n音量: {volume}%\n滚轮调节音量，左键静音/恢复，中键切换麦克风",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "on-click-right": "ghostty -e sh -lc 'wpctl status; printf \"\\n按回车关闭\"; read _'",
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
    "scroll-step": 5,
    "max-volume": 100,
    "smooth-scrolling-threshold": 1
  },
  "backlight#brightness": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "󰃞",
      "󰃟",
      "󰃠"
    ],
    "tooltip": true,
    "tooltip-format": "屏幕亮度: {percent}%\n滚轮调节亮度，左键低亮度/恢复，右键查看背光信息",
    "on-click": "screen-brightness --toggle",
    "on-click-right": "ghostty -e sh -lc 'brightnessctl info; printf \"\\n按回车关闭\"; read _'",
    "on-scroll-up": "screen-brightness --up",
    "on-scroll-down": "screen-brightness --down",
    "scroll-step": 5,
    "smooth-scrolling-threshold": 1
  },
  "wireplumber#prefix": {
    "format": " {icon}",
    "format-muted": " 󰝟",
    "format-icons": {
      "default": [
        "󰕿",
        "󰖀",
        "󰕾"
      ]
    }
  },
  "tray": {
    "spacing": 8
  },
  "custom/cc": {
    "format": "󰍜",
    "on-click": "swaync-client -t ",
    "tooltip": false
  },
  "custom/poweroff": {
    "format": "  ",
    "tooltip": true,
    "tooltip-format": "打开电源菜单",
    "on-click": "wlogout --buttons-per-row 5 --column-spacing 12 --row-spacing 12 --margin 275"
  },
  "custom/wallpaper": {
    "format": "󰸉",
    "tooltip": true,
    "tooltip-format": "切换桌面背景\n左键随机切换，右键重启背景服务",
    "on-click": "wallpaper-random --once",
    "on-click-right": "systemctl --user restart wallpaper-random.service niri-overview-wallpaper.service"
  },
  "custom/opacity": {
    "format": "◐",
    "tooltip": true,
    "tooltip-format": "调整当前程序透明度\n左键切换，右键恢复，滚轮调节",
    "on-click": "window-opacity --toggle",
    "on-click-right": "window-opacity --reset",
    "on-scroll-up": "window-opacity --up",
    "on-scroll-down": "window-opacity --down",
    "scroll-step": 5,
    "smooth-scrolling-threshold": 1
  },
  "custom/shortcuts": {
    "format": "󰌌",
    "tooltip": true,
    "tooltip-format": "显示快捷键提示\n左键打开自定义提示，右键打开 niri 原生提示",
    "on-click": "niri-shortcuts-grid",
    "on-click-right": "niri msg action show-hotkey-overlay"
  },
  "custom/trayright": {
    "format": " ",
    "tooltip": false
  },
  "hyprland/workspaces": {
    "format": "{name}"
  },
  "_vim_": "# vim: set filetype=json:"
}
