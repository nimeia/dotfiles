{
  "height": 48,
  "clock#time": {
    "format": "{:%H:%M}",
    "tooltip-format": "{:L%a, %d %b %H:%M}",
    "interval": 1,
    "tooltip": false
  },
  "clock#date": {
    "format": "{:L%a %b %d}",
    "interval": 1
  },
  "group/datetime": {
    "orientation": "horizontal",
    "drawer": {
      "transition-left-to-right": false
    },
    "modules": [
      "clock#time",
      "clock#date"
    ]
  },
  "group/battery": {
    "orientation": "horizontal",
    "modules": [
      "battery#prefix",
      "battery#suffix"
    ]
  },
  "battery#prefix": {
    "bat": "BAT0",
    "adapter": "ADP0",
    "format": " {icon}",
    "format-charging": " у°Ӯ„",
    "format-plugged": " у°Ӯ„",
    "format-full": " у°Ғ№",
    "format-icons": [
      "у°Ғә",
      "у°Ғј",
      "у°Ғҫ",
      "у°ӮҒ",
      "у°Ғ№"
    ],
    "states": {
      "warning": 30,
      "critical": 15
    },
    "interval": 10,
    "tooltip": false
  },
  "battery#suffix": {
    "bat": "BAT0",
    "adapter": "ADP0",
    "format": "{capacity}%",
    "format-charging": "{capacity}%",
    "format-plugged": "{capacity}%",
    "format-full": "{capacity}%",
    "format-time": "{H}h {M}m",
    "tooltip": true,
    "tooltip-format": "з”өжұ : {capacity}%\nеҠҹиҖ—: {power}W\nйў„и®Ўж—¶й—ҙ: {time}",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "interval": 10
  },
  "privacy": {
    "icon-size": 12,
    "icon-spacing": 8
  },
  "group/network": {
    "orientation": "horizontal",
    "drawer": {},
    "modules": [
      "network#status",
      "network#uplprefix",
      "network#up",
      "network#dnlprefix",
      "network#down"
    ]
  },
  "network#statusprefix": {
    "format-wifi": " пҮ«",
    "format-ethernet": " у°ҲҖ",
    "format-disconnected": " у°Ңҷ",
    "tooltip-format": "{ifname} via {gwaddr} ",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ",
    "tooltip-format-ethernet": "{ifname} ",
    "tooltip-format-disconnected": "Disconnected"
  },
  "network#status": {
    "format-wifi": "{signalStrength}%",
    "format-ethernet": "LAN",
    "format-disconnected": "",
    "tooltip-format": "{ifname} via {gwaddr}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50
  },
  "network#uplprefix": {
    "format-wifi": " у°¬¬",
    "format-ethernet": " у°¬¬",
    "format-disconnected": "",
    "tooltip": false
  },
  "network#dnlprefix": {
    "format-wifi": " у°¬Ұ",
    "format-ethernet": " у°¬Ұ",
    "format-disconnected": "",
    "tooltip": false
  },
  "network#up": {
    "format-wifi": "{bandwidthUpBytes}",
    "format-ethernet": "{bandwidthUpBytes}",
    "interval": 1
  },
  "network#down": {
    "format-wifi": "{bandwidthDownBytes}",
    "format-ethernet": "{bandwidthDownBytes}",
    "interval": 1
  },
  "clock#centered": {
    "format": " {:%a, %d %b %H:%M} ",
    "interval": 1
  },
  "custom/app": {
    "format": " Applications ",
    "tooltip": false,
    "on-click": "nwg-drawer"
  },
  "mpris#prefix": {
    "format": "{status_icon}",
    "status-icons": {
      "playing": "п…„",
      "paused": "пҠӢ",
      "stopped": "пҠҚ"
    }
  },
  "mpris#suffix": {
    "format": "пҠҚ",
    "format-playing": "{dynamic} ",
    "format-paused": "{dynamic} ",
    "format-stopped": "{dynamic} ",
    "dynamic-len": 50,
    "dynamic-order": [
      "artist",
      "title"
    ]
  },
  "custom/playerctl#prefix": {
    "exec": "~/.config/waybar/scripts/playerctl-status -s 2> /dev/null ",
    "format": "{}",
    "interval": 1
  },
  "custom/playerctl#suffix": {
    "exec": "~/.config/waybar/scripts/playerctl-status 2> /dev/null",
    "format": "{}  ",
    "interval": 1
  },
  "custom/timeprefix": {
    "format": " пҖ—",
    "tooltip": false
  },
  "custom/dateprefix": {
    "format": " п„і ",
    "tooltip": false
  },
  "custom/memoryprefix": {
    "format": " у°Қӣ",
    "tooltip": false
  },
  "memory": {
    "tooltip-format": "{used:0.2f}/{total:0.2f} GB Used"
  },
  "network#cpuprefixon": {
    "format-wifi": " пғӨ",
    "format-ethernet": " пғӨ",
    "format-disconnected": "",
    "tooltip": false
  },
  "custom/cpuprefix": {
    "format": " пғӨ",
    "tooltip": false
  },
  "custom/barpadding": {
    "format": " ",
    "tooltip": false
  },
  "cpu": {
    "format": "{usage}%"
  },
  "pulseaudio#prefix": {
    "format": "{icon} {volume}%",
    "format-muted": "у°қҹ йқҷйҹі",
    "format-icons": {
      "default": [
        "у°•ҝ",
        "у°–Җ",
        "у°•ҫ"
      ]
    },
    "tooltip": true,
    "tooltip-format": "{desc}\nйҹійҮҸ: {volume}%\nж»ҡиҪ®и°ғиҠӮйҹійҮҸпјҢе·Ұй”®йқҷйҹі/жҒўеӨҚпјҢдёӯй”®еҲҮжҚўйәҰе…ӢйЈҺ",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "on-click-right": "ghostty -e sh -lc 'wpctl status; printf \"\\nжҢүеӣһиҪҰе…ій—ӯ\"; read _'",
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
    "scroll-step": 5,
    "max-volume": 100,
    "smooth-scrolling-threshold": 1
  },
  "backlight#brightness": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "у°ғһ",
      "у°ғҹ",
      "у°ғ "
    ],
    "tooltip": true,
    "tooltip-format": "еұҸе№•дә®еәҰ: {percent}%\nж»ҡиҪ®и°ғиҠӮдә®еәҰпјҢе·Ұй”®дҪҺдә®еәҰ/жҒўеӨҚпјҢеҸій”®жҹҘзңӢиғҢе…үдҝЎжҒҜ",
    "on-click": "screen-brightness --toggle",
    "on-click-right": "ghostty -e sh -lc 'brightnessctl info; printf \"\\nжҢүеӣһиҪҰе…ій—ӯ\"; read _'",
    "on-scroll-up": "screen-brightness --up",
    "on-scroll-down": "screen-brightness --down",
    "scroll-step": 5,
    "smooth-scrolling-threshold": 1
  },
  "wireplumber#prefix": {
    "format": " {icon}",
    "format-muted": " у°қҹ",
    "format-icons": {
      "default": [
        "у°•ҝ",
        "у°–Җ",
        "у°•ҫ"
      ]
    }
  },
  "tray": {
    "spacing": 8
  },
  "custom/cc": {
    "format": "у°Қң",
    "on-click": "swaync-client -t ",
    "tooltip": false
  },
  "custom/poweroff": {
    "format": " пҖ‘ ",
    "tooltip": true,
    "tooltip-format": "жү“ејҖз”өжәҗиҸңеҚ•",
    "on-click": "power-menu"
  },
  "custom/wallpaper": {
    "format": "у°ёү",
    "tooltip": true,
    "tooltip-format": "еҲҮжҚўжЎҢйқўиғҢжҷҜ\nе·Ұй”®йҡҸжңәеҲҮжҚўпјҢеҸій”®йҮҚеҗҜиғҢжҷҜжңҚеҠЎ",
    "on-click": "wallpaper-random --once",
    "on-click-right": "systemctl --user restart wallpaper-random.service niri-overview-wallpaper.service"
  },
  "custom/opacity": {
    "format": "в—җ",
    "tooltip": true,
    "tooltip-format": "и°ғж•ҙеҪ“еүҚзЁӢеәҸйҖҸжҳҺеәҰ\nе·Ұй”®еҲҮжҚўпјҢеҸій”®жҒўеӨҚпјҢж»ҡиҪ®и°ғиҠӮ",
    "on-click": "window-opacity --toggle",
    "on-click-right": "window-opacity --reset",
    "on-scroll-up": "window-opacity --up",
    "on-scroll-down": "window-opacity --down",
    "scroll-step": 5,
    "smooth-scrolling-threshold": 1
  },
  "custom/shortcuts": {
    "format": "у°ҢҢ",
    "tooltip": true,
    "tooltip-format": "жҳҫзӨәеҝ«жҚ·й”®жҸҗзӨә\nе·Ұй”®жү“ејҖиҮӘе®ҡд№үжҸҗзӨәпјҢеҸій”®жү“ејҖ niri еҺҹз”ҹжҸҗзӨә",
    "on-click": "niri-shortcuts-grid",
    "on-click-right": "niri msg action show-hotkey-overlay"
  },
  "custom/trayright": {
    "format": " ",
    "tooltip": false
  },
  "hyprland/workspaces": {
    "format": "{name}"
  },
  "_vim_": "# vim: set filetype=json:"
}
