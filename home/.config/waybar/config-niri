{
  "modules-left": [
    "group/leftside"
  ],
  "modules-center": [
    "group/windowcenter"
  ],
  "layer": "bottom",
  "exclusive": true,
  "on-sigusr1": "toggle",
  "include": [
    "~/.config/waybar/config-common",
    "~/.config/waybar/config-common-tiling"
  ],
  "niri/window": {
    "format": " {} ",
    "separate-outputs": false
  },
  "group/windowcenter": {
    "orientation": "horizontal",
    "modules": [
      "niri/window",
      "group/windowactions"
    ]
  },
  "group/windowactions": {
    "orientation": "horizontal",
    "modules": [
      "custom/window-layout-half",
      "custom/window-layout-third",
      "custom/window-layout-wide",
      "custom/window-layout-stack",
      "custom/window-maximize",
      "custom/window-fullscreen",
      "custom/window-close"
    ]
  },
  "custom/window-layout-half": {
    "format": "½",
    "tooltip": true,
    "tooltip-format": "左右 50% 布局\n右键恢复默认宽度",
    "on-click": "niri-layout half",
    "on-click-right": "niri-layout reset"
  },
  "custom/window-layout-third": {
    "format": "⅓",
    "tooltip": true,
    "tooltip-format": "三列 1/3 布局\n右键恢复默认宽度",
    "on-click": "niri-layout third",
    "on-click-right": "niri-layout reset"
  },
  "custom/window-layout-wide": {
    "format": "⅔",
    "tooltip": true,
    "tooltip-format": "主窗口 2/3 布局\n右键恢复默认宽度",
    "on-click": "niri-layout wide",
    "on-click-right": "niri-layout reset"
  },
  "custom/window-layout-stack": {
    "format": "▤",
    "tooltip": true,
    "tooltip-format": "上下堆叠布局\n右键移出底部窗口",
    "on-click": "niri-layout stack",
    "on-click-right": "niri-layout unstack"
  },
  "custom/window-maximize": {
    "format": "󰖯",
    "tooltip": true,
    "tooltip-format": "最大化当前程序",
    "on-click": "niri msg action maximize-window-to-edges"
  },
  "custom/window-fullscreen": {
    "format": "󰊓",
    "tooltip": true,
    "tooltip-format": "全屏显示当前程序",
    "on-click": "niri-fullscreen --toggle"
  },
  "custom/window-close": {
    "format": "󰅖",
    "tooltip": true,
    "tooltip-format": "关闭当前程序",
    "on-click": "niri msg action close-window"
  },
  "group/leftside": {
    "orientation": "horizontal",
    "modules": [
      "niri/workspaces",
      "mpris#prefix",
      "mpris#suffix"
    ]
  },
  "_vim_": "# vim: set filetype=json:"
}
